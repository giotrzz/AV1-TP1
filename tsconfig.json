{
  "compilerOptions": {

    "target": "ES2020",
    "module": "CommonJS",      
    "rootDir": "./src",        
    "outDir": "./dist",  
    "types": ["node"],      

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,   
    "sourceMap": true,         
    "declaration": true,
    "removeComments": true     
  },
  "include": ["src/**/*"],     
  "exclude": ["node_modules"]
}

